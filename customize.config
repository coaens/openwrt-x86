###### 1. ESXi 虚拟化与架构优化 ######
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
# 直接生成 ESXi 专用的虚拟磁盘格式 (.vmdk)
CONFIG_TARGET_VMDK=y
# 分区建议 512MB，确保系统插件运行空间充足
CONFIG_TARGET_ROOTFS_PARTSIZE=512
# ESXi 必备：提供心跳检测、IP显示及平滑关机支持
CONFIG_PACKAGE_open-vm-tools=y
# VMWare 专属虚拟网卡驱动，提升网络吞吐性能
CONFIG_PACKAGE_kmod-vmxnet3=y

###### 2. 你要求新增的热门插件 (2026 主流) ######
CONFIG_PACKAGE_luci-app-istore=y         # iStore：应用商店，点点鼠标即可安装扩展
CONFIG_PACKAGE_luci-app-homeproxy=y      # HomeProxy：基于 Sing-box 的高性能代理工具
CONFIG_PACKAGE_luci-app-lucky=y          # Lucky：全能型工具（包含 DDNS、穿透、反代等）
CONFIG_PACKAGE_luci-app-smartdns=y       # SmartDNS：本地 DNS 加速，秒开网页必备
CONFIG_PACKAGE_luci-app-pbr=y            # 策略路由：指定不同设备走不同的上网通道
CONFIG_PACKAGE_luci-app-nlbwmon=y        # 带宽监控：实时查看每个设备的流量使用情况

###### 3. 补全你之前的 DIY 功能 (含修正包名) ######
# --- 科学上网 ---
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y

# --- 远程访问与 DDNS ---
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y  # 修正：原 v4 包名已变更
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-app-frps=y
CONFIG_PACKAGE_luci-app-wol=y           # 网络唤醒：远程开启家里电脑

# --- IPTV 与组播支持 ---
CONFIG_PACKAGE_luci-app-udpxy=y          # 组播转单播，用于在内网看 IPTV
CONFIG_PACKAGE_luci-app-omcproxy=y       # IGMP 代理，高清直播流必备

# --- 存储与系统增强 ---
CONFIG_PACKAGE_luci-app-diskman=y       # 图形化磁盘管理，x86 环境必备
CONFIG_PACKAGE_luci-app-samba4=y        # 修正：旧版 samba 已废弃，现用版本 4
# CONFIG_PACKAGE_autosamba is not set    # 建议禁用以减少冲突
CONFIG_PACKAGE_luci-app-ttyd=y           # 网页终端，免客户端进 SSH
CONFIG_PACKAGE_luci-app-vlmcsd=y         # KMS 激活服务器
CONFIG_PACKAGE_luci-app-ramfree=y        # 内存释放工具
CONFIG_PACKAGE_luci-app-autoreboot=y     # 定时重启

###### 4. 主题美化 ######
CONFIG_PACKAGE_luci-theme-argon=y        # 目前公认最好看的适配主题
CONFIG_PACKAGE_luci-theme-bootstrap=y
