###### 1. ESXi 虚拟化与架构优化 ######
CONFIG_TARGET_x86=y                       # 目标架构: x86
CONFIG_TARGET_x86_64=y                    # 64位系统: 支持大内存与现代硬件
CONFIG_TARGET_x86_64_DEVICE_generic=y     # 通用设备驱动: 适配 ESXi 虚拟机
CONFIG_VMDK_IMAGES=y                      # 输出格式: 直接生成 ESXi 可挂载的 .vmdk 文件
CONFIG_TARGET_ROOTFS_PARTSIZE=512         # 分区大小: 512MB，预留充足空间给插件
CONFIG_PACKAGE_open-vm-tools=y            # ESXi工具: 提供心跳检测与宿主机平滑关机
CONFIG_PACKAGE_kmod-vmxnet3=y             # 虚拟网卡: VMWare VMXNET3 万兆网卡驱动

###### 2. 你要求新增的插件 (含新补充项) ######
CONFIG_PACKAGE_luci-app-acme=y           # ACME: 自动申请与续签 SSL 证书（如 Let's Encrypt）
CONFIG_PACKAGE_luci-app-cloudflared=y    # Cloudflared: Cloudflare Tunnel 内网穿透隧道
CONFIG_PACKAGE_ddns-go=y                 # ddns-go: 简单好用的多平台动态域名解析工具
CONFIG_PACKAGE_luci-app-filebrowser=y    # FileBrowser: 网页版文件管理器，支持在线预览与分享
CONFIG_PACKAGE_luci-app-softethervpn=y   # SoftEtherVPN: 强大的多协议 VPN 服务器（支持 L2TP/OpenVPN）
CONFIG_PACKAGE_luci-app-istore=y         # iStore: 类似手机应用商店的插件管理中心
CONFIG_PACKAGE_luci-app-homeproxy=y      # HomeProxy: 基于 Sing-box 的高性能透明代理
CONFIG_PACKAGE_luci-app-lucky=y          # Lucky: 全能工具箱（包含 DDNS、反代、穿透）
CONFIG_PACKAGE_luci-app-smartdns=y       # SmartDNS: DNS 加速，通过并发查询优化响应速度
CONFIG_PACKAGE_luci-app-pbr=y            # 策略路由: 控制不同设备/流量走不同的上网出口
CONFIG_PACKAGE_luci-app-nlbwmon=y        # 带宽监控: 实时统计每个设备的流量消耗情况

###### 3. 补全 DIY 功能与冲突修复 ######
# --- 网络与 IPTV ---
CONFIG_PACKAGE_luci-app-udpxy=y          # udpxy: IPTV 组播 UDP 信号转 HTTP 单播信号
CONFIG_PACKAGE_luci-app-omcproxy=y       # omcproxy: IGMP 代理，处理 4K IPTV 数据流

# --- 存储共享 (已修复 Samba 冲突) ---
CONFIG_PACKAGE_luci-app-ksmbd=y          # ksmbd: 内核态轻量化 SMB 共享（替代旧版 Samba 避免报错）
# CONFIG_PACKAGE_autosamba is not set    # 建议禁用以减少冲突
CONFIG_PACKAGE_luci-app-diskman=y        # 磁盘管理: 图形化管理硬盘分区与挂载

# --- 科学上网 (SSR Plus+) ---
CONFIG_PACKAGE_luci-app-ssr-plus=y       # SSR Plus+: 经典上网插件
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y # 核心: 包含 Xray 协议支持

# --- 基础工具 ---
CONFIG_PACKAGE_luci-app-ddns=y           # 基础 DDNS: 官方动态域名服务
CONFIG_PACKAGE_ddns-scripts-cloudflare=y  # CF脚本: 修正后的 Cloudflare 更新脚本
CONFIG_PACKAGE_luci-app-wol=y            # 网络唤醒: 远程开启局域网内的电脑
CONFIG_PACKAGE_luci-app-ttyd=y           # 网页终端: 浏览器直接进入 SSH
CONFIG_PACKAGE_luci-app-vlmcsd=y         # KMS服务: 激活内网 Windows/Office
CONFIG_PACKAGE_luci-app-ramfree=y        # 释放内存: 手动/定时清理缓存释放 RAM
CONFIG_PACKAGE_luci-app-autoreboot=y     # 定时重启: 保持系统长期稳定运行

###### 4. 界面与协议 ######
CONFIG_PACKAGE_luci-theme-argon=y        # 主题: Argon 适配皮肤
CONFIG_PACKAGE_luci-theme-bootstrap=y
